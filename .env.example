# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenClaw Gateway
OPENCLAW_GATEWAY_TOKEN=generate-a-secure-token-here

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI (embeddings only)
OPENAI_API_KEY=your-openai-api-key

# Slack — one app per agent
SLACK_BOT_TOKEN_SAM=xoxb-sam-bot-token
SLACK_APP_TOKEN_SAM=xapp-sam-app-token
SLACK_BOT_TOKEN_GILL=xoxb-gill-bot-token
SLACK_APP_TOKEN_GILL=xapp-gill-app-token
SLACK_BOT_TOKEN_SOPHIE=xoxb-sophie-bot-token
SLACK_APP_TOKEN_SOPHIE=xapp-sophie-app-token
