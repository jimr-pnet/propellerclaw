{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "trustedProxies": ["0.0.0.0/0"],
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": [
        "https://openclaw-gateway-production-fef1.up.railway.app",
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5-nano",
        "fallbacks": ["openai/gpt-4o-mini"]
      }
    },
    "list": [
      {
        "id": "sam",
        "name": "Sam's Agent",
        "workspace": "/home/node/.openclaw/workspace",
        "agentDir": "/home/node/.openclaw/agents/sam"
      },
      {
        "id": "gill",
        "name": "Gill's Agent",
        "workspace": "/home/node/.openclaw/workspace",
        "agentDir": "/home/node/.openclaw/agents/gill"
      },
      {
        "id": "sophie",
        "default": true,
        "name": "Sophie",
        "workspace": "/home/node/.openclaw/workspace",
        "agentDir": "/home/node/.openclaw/agents/sophie"
      }
    ]
  }
}
